{
  "id": "LINUX_CIS_CENTOS",
  "name": "CentOS \u57fa\u7ebf (CIS + \u7b49\u4fdd 2.0, \u501f\u9274 Elkeid)",
  "version": "1.0",
  "description": "\u5b57\u8282\u8df3\u52a8\u6700\u4f73\u5b9e\u8df5-centos\u57fa\u7ebf\u68c0\u67e5 / bytedance Standard-centos Security Baseline Check\n\u501f\u9274 Elkeid baseline (Apache 2.0, https://github.com/bytedance/Elkeid).",
  "os_family": [
    "centos",
    "rocky",
    "almalinux",
    "oracle",
    "rhel"
  ],
  "enabled": true,
  "rules": [
    {
      "rule_id": "LINUX_CIS_CENTOS_0001",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u8bbe\u7f6e\u5bc6\u7801\u5931\u6548\u65f6\u95f4<=90\u5929 / Ensure password expiration is 180 days or less",
      "description": "\u8bf7\u8bbe\u7f6e\u5bc6\u7801\u5931\u6548\u65f6\u95f4\uff0c\u5b9a\u671f\u4fee\u6539\u5bc6\u7801\u7b56\u7565\uff0c\u51cf\u5c11\u5bc6\u7801\u88ab\u6cc4\u6f0f\u548c\u731c\u6d4b\u98ce\u9669\uff0c\u4f7f\u7528\u975e\u5bc6\u7801\u767b\u9646\u65b9\u5f0f(\u5982\u5bc6\u94a5\u5bf9)\u8bf7\u5ffd\u7565\u6b64\u9879\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/login.defs",
              "\\s*\\t*PASS_MAX_DAYS\\s*\\t*(\\d+)"
            ],
            "result": "$(<=)90"
          }
        ]
      },
      "fix": {
        "suggestion": "\u4f7f\u7528\u975e\u5bc6\u7801\u767b\u9646\u65b9\u5f0f\u5982\u5bc6\u94a5\u5bf9\uff0c\u8bf7\u5ffd\u7565\u6b64\u9879\u3002\n\u91c7\u7528root\u6743\u9650\u767b\u5f55\u7cfb\u7edf;\n\u8f93\u5165:\n\u5728 /etc/login.defs;\n\u5c06 PASS_MAX_DAYS \u53c2\u6570\u8bbe\u7f6e<=90",
        "command": "cp /etc/login.defs /etc/login.defs.mxbak && (grep -qE '^\\s*PASS_MAX_DAYS[ \\t]' /etc/login.defs && sed -ri 's|^\\s*PASS_MAX_DAYS[ \\t].*|PASS_MAX_DAYS 90|' /etc/login.defs || echo 'PASS_MAX_DAYS 90' >> /etc/login.defs)"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0002",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u5bc6\u7801\u4fee\u6539\u6700\u77ed\u5468\u671f>=2\u5929 / Ensure minimum days between password changes is 2 or more",
      "description": "\u8bbe\u7f6e\u5bc6\u7801\u4fee\u6539\u6700\u5c0f\u95f4\u9694\u65f6\u95f4\uff0c\u9650\u5236\u5bc6\u7801\u66f4\u6539\u8fc7\u4e8e\u9891\u7e41\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/login.defs",
              "\\s*\\t*PASS_MIN_DAYS\\s*\\t*(\\d+)"
            ],
            "result": "$(>=)2"
          }
        ]
      },
      "fix": {
        "suggestion": "\u5728 /etc/login.defs \u4e2d\u5c06 PASS_MIN_DAYS \u53c2\u6570\u8bbe\u7f6e\u4e3a >=2\u3002",
        "command": "cp /etc/login.defs /etc/login.defs.mxbak && (grep -qE '^\\s*PASS_MIN_DAYS[ \\t]' /etc/login.defs && sed -ri 's|^\\s*PASS_MIN_DAYS[ \\t].*|PASS_MIN_DAYS 2|' /etc/login.defs || echo 'PASS_MIN_DAYS 2' >> /etc/login.defs)"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0003",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u5bc6\u7801\u5230\u671f\u65f6\u95f4\u8b66\u544a>=7\u5929 / Ensure password expiration warning days is 7 or more",
      "description": "\u786e\u4fdd\u5bc6\u7801\u5230\u671f\u8b66\u544a\u5929\u6570\u4e3a7\u6216\u66f4\u591a\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/login.defs",
              "\\s*\\t*PASS_WARN_AGE\\s*\\t*(\\d+)"
            ],
            "result": "$(>=)7"
          }
        ]
      },
      "fix": {
        "suggestion": "\u5728 /etc/login.defs \u4e2d\u5c06 PASS_WARN_AGE \u53c2\u6570\u8bbe\u7f6e\u4e3a >=7\u3002",
        "command": "cp /etc/login.defs /etc/login.defs.mxbak && (grep -qE '^\\s*PASS_WARN_AGE[ \\t]' /etc/login.defs && sed -ri 's|^\\s*PASS_WARN_AGE[ \\t].*|PASS_WARN_AGE 7|' /etc/login.defs || echo 'PASS_WARN_AGE 7' >> /etc/login.defs)"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0004",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u5bc6\u7801\u590d\u6742\u6027\u68c0\u67e5 / Ensure password creation requirements are configured",
      "description": "\u68c0\u67e5\u5bc6\u7801\u957f\u5ea6\u548c\u5bc6\u7801\u662f\u5426\u4f7f\u7528\u591a\u79cd\u5b57\u7b26\u7c7b\u578b\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/security/pwquality.conf",
              "^\\s*minclass\\s+\\t*=\\s+\\t*(\\d+)"
            ],
            "result": "$(>=)3"
          },
          {
            "type": "file_line_expr",
            "param": [
              "/etc/security/pwquality.conf",
              "^\\s*minlen\\s+\\t*=\\s+\\t*(\\d+)"
            ],
            "result": "$(>=)8"
          },
          {
            "type": "file_line_expr",
            "param": [
              "/etc/pam.d/password-auth",
              "try_first_pass.*retry=(\\d+)"
            ],
            "result": "$(<=)3"
          },
          {
            "type": "file_line_expr",
            "param": [
              "/etc/pam.d/system-auth",
              "try_first_pass.*retry=(\\d+)"
            ],
            "result": "$(<=)3"
          }
        ]
      },
      "fix": {
        "suggestion": "1.\u7f16\u8f91/etc/security/pwquality.conf\u6587\u4ef6\uff0c\u5c06minlen\u8bbe\u7f6e\u4e3a>=8\u7684\u503c\u3002\n2.\u7f16\u8f91/etc/security/pwquality.conf\u6587\u4ef6\uff0c\u5c06minclass\u8bbe\u7f6e\u4e3a>=3\u7684\u503c\u3002\n3.\u7f16\u8f91/etc/pam.d/password-auth\u548c/etc/pam.d/system-auth \u5c06pam_pwquality.so\u8fd9\u4e00\u884c\u7684try_first_pass\u540e\u8fb9\u7684retry=\u8bbe\u7f6e\u4e3a<=3\u3002",
        "command": "F=/etc/security/pwquality.conf; cp $F $F.mxbak; (grep -qE '^\\s*minlen' $F && sed -ri 's|^\\s*#?\\s*minlen.*|minlen = 8|' $F || echo 'minlen = 8' >> $F); (grep -qE '^\\s*minclass' $F && sed -ri 's|^\\s*#?\\s*minclass.*|minclass = 3|' $F || echo 'minclass = 3' >> $F); for P in /etc/pam.d/password-auth /etc/pam.d/system-auth; do cp $P $P.mxbak; if grep -qE 'pam_pwquality.so.*retry=[0-9]+' $P; then sed -ri 's|(pam_pwquality.so[^\\n]*retry=)[0-9]+|\\13|' $P; elif grep -q 'pam_pwquality.so' $P; then sed -ri 's|(pam_pwquality.so.*)|\\1 retry=3|' $P; fi; done"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0005",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u786e\u4fddroot\u662f\u552f\u4e00UID\u4e3a0\u7684\u7528\u6237 / Ensure root is the only UID 0 account",
      "description": "\u9664root\u4ee5\u5916\u5176\u4ed6UID\u4e3a0\u7684\u7528\u6237\u90fd\u5e94\u8be5\u5220\u9664\uff0c\u6216\u8005\u4e3a\u5176\u5206\u914d\u65b0\u7684UID\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/passwd"
            ],
            "result": "$(not)^root:$(&&)^\\w+:\\w+:0:"
          }
        ]
      },
      "fix": {
        "suggestion": "\u9664root\u4ee5\u5916\u5176\u4ed6UID\u4e3a0\u7684\u7528\u6237(\u67e5\u770b\u547d\u4ee4cat /etc/passwd | awk -F: '($3 == 0) { print $1 }'|grep -v '^root$' )\u90fd\u5e94\u8be5\u5220\u9664\uff0c\u6216\u8005\u4e3a\u5176\u5206\u914d\u65b0\u7684UID\u3002"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0006",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u68c0\u67e5\u662f\u5426\u9650\u5236\u5bc6\u7801\u91cd\u7528 / Ensure password reuse is limited",
      "description": "\u5e94\u9650\u5236\u7528\u6237\u4e4b\u95f4\u91cd\u7528\u5bc6\u7801\u7684\u884c\u4e3a\uff0c\u964d\u4f4e\u5bc6\u7801\u6cc4\u6f0f\u7684\u98ce\u9669\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/pam.d/password-auth",
              "^password\\s+sufficient\\s+pam_unix.so.*remember=(\\d+)"
            ],
            "result": "$(>=)5"
          },
          {
            "type": "file_line_expr",
            "param": [
              "/etc/pam.d/system-auth",
              "^password\\s+sufficient\\s+pam_unix.so.*remember=(\\d+)"
            ],
            "result": "$(>=)5"
          }
        ]
      },
      "fix": {
        "suggestion": "\u5728/etc/pam.d/password-auth\u548c/etc/pam.d/system-auth\u4e2dpassword sufficient pam_unix.so \u8fd9\u884c\u63d2\u5165\u914d\u7f6eremember\u8bbe\u7f6e\u4e3a>=5\u7684\u503c\uff0c\u5efa\u8bae\u4e3a5\uff0c\u5373\u5728\u884c\u672b\u5c3e\u52a0\u4e0a\u53c2\u6570remember=5\u3002",
        "command": "for P in /etc/pam.d/password-auth /etc/pam.d/system-auth; do cp $P $P.mxbak; if grep -qE '^password\\s+sufficient\\s+pam_unix.so.*remember=[0-9]+' $P; then sed -ri 's|(^password\\s+sufficient\\s+pam_unix.so[^\\n]*remember=)[0-9]+|\\15|' $P; elif grep -qE '^password\\s+sufficient\\s+pam_unix.so' $P; then sed -ri 's|(^password\\s+sufficient\\s+pam_unix.so.*)|\\1 remember=5|' $P; fi; done"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0007",
      "category": "\u8eab\u4efd\u9274\u522b",
      "title": "\u7a7a\u53e3\u4ee4\u8d26\u6237\u68c0\u6d4b / Ensure password fields are not empty",
      "description": "\u68c0\u67e5\u7cfb\u7edf\u7a7a\u5bc6\u7801\u8d26\u6237\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/shadow"
            ],
            "result": "^\\w+::"
          }
        ]
      },
      "fix": {
        "suggestion": "\u4e3a\u7a7a\u53e3\u4ee4\u7684\u7528\u6237\u8bbe\u7f6e\u5b89\u5168\u5bc6\u7801\uff0c\u6216\u8005\u6267\u884cpasswd -l <username>\u9501\u5b9a\u7528\u6237\u3002"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0008",
      "category": "SSH\u68c0\u6d4b",
      "title": "SSH\u7a7a\u5bc6\u7801\u68c0\u6d4b / Ensure SSH PermitEmptyPasswords is disabled",
      "description": "\u7981\u6b62SSH\u7a7a\u5bc6\u7801\u7528\u6237\u767b\u5f55\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/ssh/sshd_config"
            ],
            "result": "PermitEmptyPasswords\\s*\\t*no"
          }
        ]
      },
      "fix": {
        "suggestion": "\u7f16\u8f91\u6587\u4ef6/etc/ssh/sshd_config\uff0c\u5c06PermitEmptyPasswords\u914d\u7f6e\u4e3ano\u3002",
        "command": "cp /etc/ssh/sshd_config /etc/ssh/sshd_config.mxbak && (grep -qiE '^\\s*#?\\s*PermitEmptyPasswords' /etc/ssh/sshd_config && sed -ri 's|^\\s*#?\\s*PermitEmptyPasswords.*|PermitEmptyPasswords no|I' /etc/ssh/sshd_config || echo 'PermitEmptyPasswords no' >> /etc/ssh/sshd_config); if sshd -t; then systemctl restart sshd; else mv /etc/ssh/sshd_config.mxbak /etc/ssh/sshd_config; exit 1; fi",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0009",
      "category": "SSH\u68c0\u6d4b",
      "title": "SSH\u5931\u8d25\u5c1d\u8bd5\u6b21\u6570<5 / Ensure SSH MaxAuthTries is set to 5 or less",
      "description": "\u8bbe\u7f6e\u8f83\u4f4e\u7684Max AuthTrimes\u53c2\u6570\u5c06\u964d\u4f4eSSH\u670d\u52a1\u5668\u88ab\u66b4\u529b\u653b\u51fb\u6210\u529f\u7684\u98ce\u9669\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/ssh/sshd_config",
              "^MaxAuthTries\\s*\\t*(\\d+)"
            ],
            "result": "$(<)5"
          }
        ]
      },
      "fix": {
        "suggestion": "\u5728/etc/ssh/sshd_config\u4e2d\u53d6\u6d88MaxAuthTries\u6ce8\u91ca\u7b26\u53f7#\uff0c\u8bbe\u7f6e\u6700\u5927\u5bc6\u7801\u5c1d\u8bd5\u5931\u8d25\u6b21\u6570\u5c0f\u4e8e5\u3002",
        "command": "cp /etc/ssh/sshd_config /etc/ssh/sshd_config.mxbak && (grep -qiE '^\\s*#?\\s*MaxAuthTries' /etc/ssh/sshd_config && sed -ri 's|^\\s*#?\\s*MaxAuthTries.*|MaxAuthTries 4|I' /etc/ssh/sshd_config || echo 'MaxAuthTries 4' >> /etc/ssh/sshd_config); if sshd -t; then systemctl restart sshd; else mv /etc/ssh/sshd_config.mxbak /etc/ssh/sshd_config; exit 1; fi",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0010",
      "category": "\u5b89\u5168\u5ba1\u8ba1",
      "title": "\u786e\u4fdd\u5f00\u542f\u65e5\u5fd7\u5b88\u62a4\u8fdb\u7a0b(auditd) / Ensure auditd Service is enabled",
      "description": "\u786e\u4fddauditd\u670d\u52a1\u5df2\u542f\u7528\uff0c\u8bb0\u5f55\u65e5\u5fd7\u7528\u4e8e\u5ba1\u8ba1\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "command_exec",
            "param": [
              "systemctl is-enabled auditd"
            ],
            "result": "enabled"
          },
          {
            "type": "command_exec",
            "param": [
              "systemctl status auditd"
            ],
            "result": "active \\(running\\)"
          }
        ]
      },
      "fix": {
        "suggestion": "\u8fd0\u884c\u4ee5\u4e0b\u547d\u4ee4\u542f\u7528auditd\u670d\u52a1\uff1a\nsystemctl --now enable auditd",
        "command": "systemctl enable --now auditd"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0011",
      "category": "SSH\u68c0\u6d4b",
      "title": "\u51cf\u5c11\u7a7a\u95f2\u8d85\u65f6\u9000\u51fa\u65f6\u95f4 / Ensure SSH Idle Timeout Interval is configured",
      "description": "\u8bbe\u7f6eSSH\u7a7a\u95f2\u8d85\u65f6\u9000\u51fa\u65f6\u95f4,\u53ef\u964d\u4f4e\u672a\u6388\u6743\u7528\u6237\u8bbf\u95ee\u5176\u4ed6\u7528\u6237ssh\u4f1a\u8bdd\u7684\u98ce\u9669\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/ssh/sshd_config",
              "ClientAliveInterval\\s*\\t*(\\d+)"
            ],
            "result": "$(<=)900"
          },
          {
            "type": "file_line_expr",
            "param": [
              "/etc/ssh/sshd_config",
              "ClientAliveCountMax\\s*\\t*(\\d+)"
            ],
            "result": "$(<=)3"
          }
        ]
      },
      "fix": {
        "suggestion": "\u7f16\u8f91/etc/ssh/sshd_config\uff0c\u5c06ClientAliveInterval \u8bbe\u7f6e\u4e3a<=900(15\u5206\u949f)\uff0c\u5c06ClientAliveCountMax\u8bbe\u7f6e\u4e3a0-3\u4e4b\u95f4\u3002",
        "command": "F=/etc/ssh/sshd_config; cp $F $F.mxbak; (grep -qiE '^\\s*#?\\s*ClientAliveInterval' $F && sed -ri 's|^\\s*#?\\s*ClientAliveInterval.*|ClientAliveInterval 300|I' $F || echo 'ClientAliveInterval 300' >> $F); (grep -qiE '^\\s*#?\\s*ClientAliveCountMax' $F && sed -ri 's|^\\s*#?\\s*ClientAliveCountMax.*|ClientAliveCountMax 3|I' $F || echo 'ClientAliveCountMax 3' >> $F); if sshd -t; then systemctl restart sshd; else mv $F.mxbak $F; exit 1; fi",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0012",
      "category": "SSH\u68c0\u6d4b",
      "title": "\u786e\u4fddlog level\u4e3ainfo / Ensure SSH LogLevel is set to INFO",
      "description": "\u786e\u4fddSSH LogLevel\u8bbe\u7f6e\u4e3aINFO,\u8bb0\u5f55\u767b\u5f55\u548c\u6ce8\u9500\u6d3b\u52a8\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_line_expr",
            "param": [
              "/etc/ssh/sshd_config"
            ],
            "result": "LogLevel\\s*\\t*INFO"
          }
        ]
      },
      "fix": {
        "suggestion": "\u7f16\u8f91 /etc/ssh/sshd_config \u6587\u4ef6\u4ee5\u6309\u5982\u4e0b\u65b9\u5f0f\u8bbe\u7f6e\u53c2\u6570(\u53d6\u6d88\u6ce8\u91ca):\nLogLevel INFO",
        "command": "cp /etc/ssh/sshd_config /etc/ssh/sshd_config.mxbak && (grep -qiE '^\\s*#?\\s*LogLevel' /etc/ssh/sshd_config && sed -ri 's|^\\s*#?\\s*LogLevel.*|LogLevel INFO|I' /etc/ssh/sshd_config || echo 'LogLevel INFO' >> /etc/ssh/sshd_config); if sshd -t; then systemctl restart sshd; else mv /etc/ssh/sshd_config.mxbak /etc/ssh/sshd_config; exit 1; fi",
        "restart_services": [
          "sshd"
        ]
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0014",
      "category": "\u5b89\u5168\u5ba1\u8ba1",
      "title": "\u786e\u4fdd\u5f00\u542f\u65e5\u5fd7\u5b88\u62a4\u8fdb\u7a0b(rsyslog) / Ensure rsyslog Service is enabled",
      "description": "\u786e\u4fddrsyslog\u670d\u52a1\u5df2\u542f\u7528\uff0c\u8bb0\u5f55\u65e5\u5fd7\u7528\u4e8e\u5ba1\u8ba1\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "command_exec",
            "param": [
              "systemctl is-enabled rsyslog"
            ],
            "result": "enabled"
          },
          {
            "type": "command_exec",
            "param": [
              "systemctl status rsyslog"
            ],
            "result": "active \\(running\\)"
          }
        ]
      },
      "fix": {
        "suggestion": "\u8fd0\u884c\u4ee5\u4e0b\u547d\u4ee4\u542f\u7528rsyslog\u670d\u52a1\uff1a\nsystemctl --now enable rsyslog",
        "command": "systemctl enable --now rsyslog"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0015",
      "category": "\u5165\u4fb5\u9632\u8303",
      "title": "\u5f00\u542f\u5730\u5740\u968f\u673a\u5316(ASLR) / Ensure address space layout randomization (ASLR) is enabled",
      "description": "\u5b83\u5c06\u8fdb\u7a0b\u7684\u5185\u5b58\u7a7a\u95f4\u5730\u5740\u968f\u673a\u5316\u6765\u589e\u5927\u5165\u4fb5\u8005\u9884\u6d4b\u76ee\u7684\u5730\u5740\u96be\u5ea6\uff0c\u4ece\u800c\u964d\u4f4e\u8fdb\u7a0b\u88ab\u6210\u529f\u5165\u4fb5\u7684\u98ce\u9669\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "command_exec",
            "param": [
              "grep -Rh ^kernel\\.randomize_va_space /etc/sysctl.conf /etc/sysctl.d"
            ],
            "result": "\\s*kernel.randomize_va_space\\s*=\\s*2"
          },
          {
            "type": "command_exec",
            "param": [
              "sysctl kernel.randomize_va_space"
            ],
            "result": "^\\s*kernel.randomize_va_space\\s*=\\s*2"
          }
        ]
      },
      "fix": {
        "suggestion": "\u5728/etc/sysctl.conf\u6587\u4ef6\u4e2d\u8bbe\u7f6e\u4ee5\u4e0b\u53c2\u6570\uff1a \nkernel.randomize_va_space = 2 \n\u6267\u884c\u547d\u4ee4\uff1a \nsysctl -w kernel.randomize_va_space=2",
        "command": "sysctl -w kernel.randomize_va_space=2 && (grep -q '^kernel.randomize_va_space' /etc/sysctl.d/90-mxsec-baseline.conf 2>/dev/null && sed -ri 's|^kernel.randomize_va_space.*|kernel.randomize_va_space = 2|' /etc/sysctl.d/90-mxsec-baseline.conf || echo 'kernel.randomize_va_space = 2' >> /etc/sysctl.d/90-mxsec-baseline.conf)"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0016",
      "category": "\u6587\u4ef6\u6743\u9650",
      "title": "\u786e\u4fdd\u914d\u7f6e\u6587\u4ef6\u7684\u5b89\u5168\u6027 / Ensure permissions on files",
      "description": "\u4e3a\u4e86\u4fdd\u8bc1\u7cfb\u7edf\u7684\u5b89\u5168\u6027\uff0c\u8bf7\u786e\u4fdd\u914d\u7f6e\u6587\u4ef6\u7684\u5b89\u5168\u6027\u548c\u552f\u4e00\u6027\uff0c\u9650\u5236\u672a\u6388\u6743\u7528\u6237\u5bf9\u914d\u7f6e\u6587\u4ef6\u7684\u4e00\u5207\u64cd\u4f5c\uff0c\u5305\u62ec\u8bbf\u95ee\u3001\u8bfb\u5199\u3001\u5220\u9664\u7b49\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_permission",
            "param": [
              "/etc/passwd",
              "644"
            ]
          },
          {
            "type": "file_permission",
            "param": [
              "/etc/shadow",
              "400"
            ]
          },
          {
            "type": "file_permission",
            "param": [
              "/etc/group",
              "644"
            ]
          },
          {
            "type": "file_permission",
            "param": [
              "/etc/gshadow",
              "400"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "\u6267\u884c\u4ee5\u4e0b5\u6761\u547d\u4ee4\nchown root:root /etc/passwd /etc/shadow /etc/group /etc/gshadow\nchmod 0644 /etc/group\nchmod 0644 /etc/passwd\nchmod 0400 /etc/shadow\nchmod 0400 /etc/gshadow",
        "command": "chown root:root /etc/passwd /etc/shadow /etc/group /etc/gshadow && chmod 0644 /etc/passwd /etc/group && chmod 0400 /etc/shadow /etc/gshadow"
      }
    },
    {
      "rule_id": "LINUX_CIS_CENTOS_0017",
      "category": "\u8bbe\u7f6e\u7528\u6237\u8bbf\u95ee\u914d\u7f6e\u6587\u4ef6\u7684\u6743\u9650",
      "title": "\u8bbe\u7f6e\u7528\u6237\u8bbf\u95ee\u914d\u7f6e\u6587\u4ef6\u7684\u6743\u9650 / Verify permissions on files",
      "description": "\u8bbe\u7f6e\u7528\u6237\u8bbf\u95ee\u914d\u7f6e\u6587\u4ef6\u7684\u6743\u9650\u3002",
      "severity": "high",
      "check": {
        "condition": "all",
        "rules": [
          {
            "type": "file_permission",
            "param": [
              "/etc/hosts.allow",
              "644"
            ]
          },
          {
            "type": "file_permission",
            "param": [
              "/etc/hosts.deny",
              "644"
            ]
          }
        ]
      },
      "fix": {
        "suggestion": "\u8fd0\u884c\u4ee5\u4e0b4\u6761\u547d\u4ee4\uff1a\nchown root:root /etc/hosts.allow\nchown root:root /etc/hosts.deny\nchmod 644 /etc/hosts.allow\nchmod 644 /etc/hosts.deny",
        "command": "touch /etc/hosts.allow /etc/hosts.deny && chown root:root /etc/hosts.allow /etc/hosts.deny && chmod 644 /etc/hosts.allow /etc/hosts.deny"
      }
    }
  ]
}