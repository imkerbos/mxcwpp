name: mxsec-control

services:
  manager:
    image: {{ .ManagerImage }}
    restart: always
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxsec-platform/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxsec-platform/certs:ro
      - {{ .DataRoot }}/logs/manager:/var/log/mxsec-platform
      - {{ .DataRoot }}/plugins:/opt/mxsec-platform/plugins
      - {{ .DataRoot }}/uploads:/opt/mxsec-platform/uploads
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    networks:
      - mxsec-control

  agentcenter:
    image: {{ .AgentCenterImage }}
    restart: always
    ports:
      - "{{ .App.GRPCPort }}:6751"
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxsec-platform/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxsec-platform/certs:ro
      - {{ .DataRoot }}/logs/agentcenter:/var/log/mxsec-platform
      - {{ .DataRoot }}/plugins:/opt/mxsec-platform/plugins
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 6751"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - mxsec-control

{{- if gt .Assignment.ConsumerReplicas 0 }}
  consumer:
    image: {{ .ConsumerImage }}
    restart: always
    volumes:
      - {{ .InstallDir }}/current/config/server.yaml:/etc/mxsec-platform/server.yaml:ro
      - {{ .InstallDir }}/current/certs:/etc/mxsec-platform/certs:ro
      - {{ .DataRoot }}/logs/consumer:/var/log/mxsec-platform
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD-SHELL", "kill -0 1 || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - mxsec-control
{{- end }}

  ui:
    image: {{ .UIImage }}
    restart: always
    depends_on:
      manager:
        condition: service_healthy
    ports:
      - "{{ .App.HTTPPort }}:80"
    volumes:
      - {{ .InstallDir }}/current/config/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - {{ .DataRoot }}/logs/nginx:/var/log/nginx
    environment:
      TZ: {{ .Timezone }}
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    networks:
      - mxsec-control

networks:
  mxsec-control:
    driver: bridge
