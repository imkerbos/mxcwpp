# Matrix Cloud Security Platform - 环境变量配置
# 复制为 .env 后按需修改；dev 默认值可直接使用
# cp .env.example .env

# === General ===
COMPOSE_PROFILES=         # 空=仅核心(MySQL+Redis+App), "full"=含Kafka+ClickHouse
VERSION=dev
TZ=Asia/Shanghai

# === MySQL ===
MYSQL_ROOT_PASSWORD=123456
MYSQL_PASSWORD=123456
MYSQL_DATABASE=mxsec
MYSQL_USER=mxsec_user
MYSQL_HOST=mysql
MYSQL_PORT=3306
DB_MAX_IDLE_CONNS=20
DB_MAX_OPEN_CONNS=200
DB_CONN_MAX_LIFETIME=1h

# === Redis ===
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100

# === Kafka (需 COMPOSE_PROFILES 含 kafka 或 full) ===
KAFKA_ENABLED=false
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_PREFIX=

# === ClickHouse (需 COMPOSE_PROFILES 含 clickhouse 或 full) ===
CLICKHOUSE_ENABLED=false
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DATABASE=mxsec
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# === Networking ===
SERVER_IP=127.0.0.1
GRPC_PORT=6751
HTTP_PORT=80
HTTPS_PORT=443
MANAGER_PORT=8080

# === Data ===
DATA_DIR=./data

# === Logging ===
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_MAX_AGE=7
LOG_RETENTION_DAYS=7

# === Agent ===
HEARTBEAT_INTERVAL=60

# === Plugins ===
PLUGINS_DIR=/opt/mxsec-platform/plugins
PLUGINS_BASE_URL=

# === JWT ===
JWT_SECRET=dev-secret-change-in-production
